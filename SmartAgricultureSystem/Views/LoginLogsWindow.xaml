<Window x:Class="SmartAgricultureSystem.Views.LoginLogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录日志" Height="500" Width="700"
        Background="#1E1E2E" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="系统登录日志" FontSize="18" FontWeight="Bold"
                       Foreground="#F9E2AF" VerticalAlignment="Center"/>
            <Button Content="刷新" Click="BtnRefresh_Click" Margin="20,0,0,0"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold" FontSize="12"
                    Padding="10,3" Cursor="Hand"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="DgLogs"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#313244" Foreground="White"
                  RowBackground="#45475A" AlternatingRowBackground="#313244"
                  Margin="0,5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                <DataGridTextColumn Header="用户名" Binding="{Binding username}" Width="100"/>
                <DataGridTextColumn Header="登录时间" Binding="{Binding loginTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="160"/>
                <DataGridTextColumn Header="结果" Width="60">
                    <DataGridTextColumn.Binding>
                        <Binding Path="isSuccess"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="失败原因" Binding="{Binding failReason}" Width="120"/>
                <DataGridTextColumn Header="IP地址" Binding="{Binding ipAddress}" Width="120"/>
                <DataGridTextColumn Header="设备" Binding="{Binding deviceInfo}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#313244" CornerRadius="5" Margin="0,5">
            <TextBlock x:Name="TxtStatus" Foreground="#6C7086" FontSize="12"
                       VerticalAlignment="Center" Margin="10,0"/>
        </Border>
    </Grid>
</Window>
