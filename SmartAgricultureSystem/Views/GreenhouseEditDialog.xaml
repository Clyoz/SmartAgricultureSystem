<Window x:Class="SmartAgricultureSystem.Views.GreenhouseEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑大棚" Height="500" Width="450"
        Background="#1E1E2E" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="大棚编号:" Foreground="#CDD6F4" Margin="0,5"/>
        <TextBox Grid.Row="1" x:Name="TxtCode" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>

        <TextBlock Grid.Row="2" Text="大棚名称:" Foreground="#CDD6F4" Margin="0,8,0,5"/>
        <TextBox Grid.Row="3" x:Name="TxtName" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>

        <TextBlock Grid.Row="4" Text="位置:" Foreground="#CDD6F4" Margin="0,8,0,5"/>
        <TextBox Grid.Row="5" x:Name="TxtLocation" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>

        <Grid Grid.Row="6" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="面积(㎡):" Foreground="#CDD6F4" Margin="0,5"/>
                <TextBox x:Name="TxtArea" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="类型:" Foreground="#CDD6F4" Margin="0,5"/>
                <ComboBox x:Name="CmbType" Background="#313244" Foreground="White" Padding="5" Margin="0,2">
                    <ComboBoxItem Content="玻璃温室"/>
                    <ComboBoxItem Content="塑料大棚"/>
                    <ComboBoxItem Content="日光温室"/>
                    <ComboBoxItem Content="连栋温室"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="7" Text="状态:" Foreground="#CDD6F4" Margin="0,8,0,5"/>
        <ComboBox Grid.Row="7" x:Name="CmbStatus" Background="#313244" Foreground="White" Padding="5"
                  Margin="0,28,0,0" SelectedIndex="0">
            <ComboBoxItem Content="空闲"/>
            <ComboBoxItem Content="种植中"/>
            <ComboBoxItem Content="维护中"/>
        </ComboBox>

        <TextBlock Grid.Row="8" Text="备注:" Foreground="#CDD6F4" Margin="0,8,0,5"/>
        <TextBox x:Name="TxtRemark" Grid.Row="8" Margin="0,25,0,0"
                 Background="#313244" Foreground="White" Padding="5"
                 TextWrapping="Wrap" AcceptsReturn="True" Height="60" VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="保存" Click="BtnSave_Click" Width="80" Margin="5,0"
                    Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="取消" Click="BtnCancel_Click" Width="80" Margin="5,0"
                    Background="#45475A" Foreground="#CDD6F4" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
