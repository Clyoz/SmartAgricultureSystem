<UserControl x:Class="SmartAgricultureSystem.Views.GreenhouseManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,0">
            <TextBlock Text="大棚管理" FontSize="20" FontWeight="Bold"
                       Foreground="#F9E2AF" VerticalAlignment="Center"/>
            <TextBlock Text="管理温室大棚信息、状态监控" FontSize="13"
                       Foreground="#6C7086" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- 操作栏 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,5">
            <Button Content="添加大棚" Command="{Binding AddGreenhouseCommand}"
                    Background="#A6E3A1" Foreground="#1E1E2E"
                    FontWeight="Bold" FontSize="12" Padding="12,5" Margin="0,0,10,0" Cursor="Hand"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="Bold" FontSize="12" Padding="12,5" Cursor="Hand"/>
        </StackPanel>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding GreenhouseList}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#313244" Foreground="White"
                  RowBackground="#45475A" AlternatingRowBackground="#313244"
                  Margin="10,5" SelectedItem="{Binding SelectedGreenhouse}"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                <DataGridTextColumn Header="大棚编号" Binding="{Binding greenhouseCode}" Width="100"/>
                <DataGridTextColumn Header="名称" Binding="{Binding name}" Width="120"/>
                <DataGridTextColumn Header="位置" Binding="{Binding location}" Width="150"/>
                <DataGridTextColumn Header="面积(㎡)" Binding="{Binding area, StringFormat={}{0:F0}}" Width="80"/>
                <DataGridTextColumn Header="类型" Binding="{Binding greenhouseType}" Width="100"/>
                <DataGridTextColumn Header="状态" Width="80">
                    <DataGridTextColumn.Binding>
                        <Binding Path="status" />
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="备注" Binding="{Binding remark}" Width="*"/>
                <DataGridTemplateColumn Header="操作" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="编辑" Click="BtnEditGreenhouse_Click"
                                        Background="#F9E2AF" Foreground="#1E1E2E"
                                        FontWeight="Bold" FontSize="11" Padding="8,2" Margin="2,0" Cursor="Hand"/>
                                <Button Content="删除" Click="BtnDeleteGreenhouse_Click"
                                        Background="#F38BA8" Foreground="#1E1E2E"
                                        FontWeight="Bold" FontSize="11" Padding="8,2" Margin="2,0" Cursor="Hand"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
