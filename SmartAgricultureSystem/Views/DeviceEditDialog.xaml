<Window x:Class="SmartAgricultureSystem.Views.DeviceEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑设备" Height="550" Width="450"
        Background="#1E1E2E" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="设备编号:" Foreground="#CDD6F4" Margin="0,5"/>
        <TextBox Grid.Row="1" x:Name="TxtDeviceCode" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>

        <TextBlock Grid.Row="2" Text="设备名称:" Foreground="#CDD6F4" Margin="0,8,0,5"/>
        <TextBox Grid.Row="3" x:Name="TxtName" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>

        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="所属大棚:" Foreground="#CDD6F4" Margin="0,5"/>
                <ComboBox x:Name="CmbGreenhouse" DisplayMemberPath="name" SelectedValuePath="id"
                          Margin="0,2">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="#1E1E2E"/>
                            <Setter Property="Foreground" Value="#F5F5F5"/>
                        </Style>
                    </ComboBox.Resources>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="设备类型:" Foreground="#CDD6F4" Margin="0,5"/>
                <ComboBox x:Name="CmbDeviceType" Margin="0,2" SelectedIndex="1">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="#1E1E2E"/>
                            <Setter Property="Foreground" Value="#F5F5F5"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="网关"/>
                    <ComboBoxItem Content="传感器节点"/>
                    <ComboBoxItem Content="控制器"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="IP地址:" Foreground="#CDD6F4" Margin="0,5"/>
                <TextBox x:Name="TxtIpAddress" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                <TextBlock Text="端口:" Foreground="#CDD6F4" Margin="0,5"/>
                <TextBox x:Name="TxtPort" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="5,0,0,0">
                <TextBlock Text="从站地址:" Foreground="#CDD6F4" Margin="0,5"/>
                <TextBox x:Name="TxtSlaveId" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="6" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="设备型号:" Foreground="#CDD6F4" Margin="0,5"/>
                <TextBox x:Name="TxtModel" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="固件版本:" Foreground="#CDD6F4" Margin="0,5"/>
                <TextBox x:Name="TxtFirmware" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="7" Text="备注:" Foreground="#CDD6F4" Margin="0,8,0,5"/>
        <TextBox Grid.Row="8" x:Name="TxtRemark"
                 Background="#313244" Foreground="White" Padding="5"
                 TextWrapping="Wrap" AcceptsReturn="True" Height="50" VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="保存" Click="BtnSave_Click" Width="80" Margin="5,0"
                    Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="取消" Click="BtnCancel_Click" Width="80" Margin="5,0"
                    Background="#45475A" Foreground="#CDD6F4" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
