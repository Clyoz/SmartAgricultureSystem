<Window x:Class="SmartAgricultureSystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="智慧农业系统 - 用户登录"
        Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="40,0">

            <!-- Logo和标题 -->
            <TextBlock Text="🌱" FontSize="48"
                       HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="智慧农业管理系统"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#A6E3A1"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <!-- 用户名 -->
            <TextBlock Text="用户名" Foreground="#CDD6F4" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtUsername"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Background="#313244" Foreground="White"
                     BorderBrush="#585B70" Padding="10,8"
                     FontSize="14" Margin="0,0,0,15"/>

            <!-- 密码 -->
            <TextBlock Text="密码" Foreground="#CDD6F4" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PwdBox"
                         Background="#313244" Foreground="White"
                         BorderBrush="#585B70" Padding="10,8"
                         FontSize="14" Margin="0,0,0,15"/>

            <!-- 验证码 -->
            <TextBlock Text="验证码" Foreground="#CDD6F4" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding InputCaptcha, UpdateSourceTrigger=PropertyChanged}"
                         Background="#313244" Foreground="White"
                         BorderBrush="#585B70" Padding="10,8"
                         FontSize="14" Margin="0,0,8,0"/>
                <!-- 验证码图片（点击刷新） -->
                <Image Grid.Column="1"
                       Source="{Binding CaptchaImage}"
                       Cursor="Hand" Height="36"
                       ToolTip="点击刷新验证码">
                    <Image.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding RefreshCaptchaCommand}"/>
                    </Image.InputBindings>
                </Image>
            </Grid>

            <!-- 记住登录 -->
            <CheckBox Content="记住登录状态（7天）"
                      IsChecked="{Binding RememberMe}"
                      Foreground="#CDD6F4" Margin="0,0,0,15"/>

            <!-- 错误提示 -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#F38BA8" FontSize="12"
                       TextWrapping="Wrap" Margin="0,0,0,10"
                       Visibility="{Binding ErrorMessage,
                           Converter={StaticResource StringToVisibilityConverter}}"/>

            <!-- 登录按钮 -->
            <Button Content="登 录"
                    Command="{Binding LoginCommand}"
                    Click="BtnLogin_Click"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    FontSize="15" FontWeight="Bold"
                    Padding="0,12" Margin="0,0,0,15"
                    Cursor="Hand"/>

            <!-- 注册链接 -->
            <TextBlock HorizontalAlignment="Center">
                <Run Text="没有账号？" Foreground="#6C7086"/>
                <Hyperlink Command="{Binding GoRegisterCommand}"
                           Foreground="#89B4FA">
                    立即注册
                </Hyperlink>
            </TextBlock>

        </StackPanel>
    </Grid>
</Window>