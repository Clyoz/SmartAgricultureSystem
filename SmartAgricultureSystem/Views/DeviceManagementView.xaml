<UserControl x:Class="SmartAgricultureSystem.Views.DeviceManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,0">
            <TextBlock Text="设备管理" FontSize="20" FontWeight="Bold"
                       Foreground="#FAB387" VerticalAlignment="Center"/>
            <TextBlock Text="管理传感器节点、网关、控制器" FontSize="13"
                       Foreground="#6C7086" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- 操作栏 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,5">
            <Button Content="添加设备" Command="{Binding AddDeviceCommand}"
                    Background="#A6E3A1" Foreground="#1E1E2E"
                    FontWeight="Bold" FontSize="12" Padding="12,5" Margin="0,0,10,0" Cursor="Hand"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="Bold" FontSize="12" Padding="12,5" Cursor="Hand"/>
        </StackPanel>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding DeviceList}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#313244" Foreground="White"
                  RowBackground="#45475A" AlternatingRowBackground="#313244"
                  Margin="10,5" SelectedItem="{Binding SelectedDevice}"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                <DataGridTextColumn Header="设备编号" Binding="{Binding deviceCode}" Width="100"/>
                <DataGridTextColumn Header="名称" Binding="{Binding name}" Width="120"/>
                <DataGridTextColumn Header="大棚ID" Binding="{Binding greenhouseId}" Width="60"/>
                <DataGridTextColumn Header="类型" Width="80">
                    <DataGridTextColumn.Binding>
                        <Binding Path="deviceType"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="IP地址" Binding="{Binding ipAddress}" Width="120"/>
                <DataGridTextColumn Header="端口" Binding="{Binding port}" Width="50"/>
                <DataGridTextColumn Header="从站地址" Binding="{Binding slaveId}" Width="60"/>
                <DataGridTextColumn Header="在线" Binding="{Binding isOnline}" Width="50"/>
                <DataGridTextColumn Header="型号" Binding="{Binding model}" Width="80"/>
                <DataGridTextColumn Header="备注" Binding="{Binding remark}" Width="*"/>
                <DataGridTemplateColumn Header="操作" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="编辑" Click="BtnEditDevice_Click"
                                        Background="#F9E2AF" Foreground="#1E1E2E"
                                        FontWeight="Bold" FontSize="11" Padding="8,2" Margin="2,0" Cursor="Hand"/>
                                <Button Content="删除" Click="BtnDeleteDevice_Click"
                                        Background="#F38BA8" Foreground="#1E1E2E"
                                        FontWeight="Bold" FontSize="11" Padding="8,2" Margin="2,0" Cursor="Hand"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
