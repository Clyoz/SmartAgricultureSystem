<Window x:Class="SmartAgricultureSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SmartAgricultureSystem.Views"
        Title="智慧农业温湿度检测与预警系统"
        Height="750" Width="1200"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Slider 自定义样式 - Catppuccin Mocha 风格 -->
        <Style x:Key="CatppuccinSliderStyle" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- 轨道 -->
                            <Border x:Name="TrackBackground" Grid.Row="1" Height="4" CornerRadius="2"
                                    Background="#45475A" Margin="0,4,0,4">
                                <Border x:Name="TrackFill" Height="4" CornerRadius="2"
                                        Background="#89B4FA" HorizontalAlignment="Left"/>
                            </Border>
                            <!-- 滑块 -->
                            <Track Grid.Row="1" x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14" Height="14" Fill="#CDD6F4" Stroke="#89B4FA" StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <!-- 左侧导航栏 -->
            <ColumnDefinition Width="*"/>
            <!-- 右侧内容区 -->
        </Grid.ColumnDefinitions>

        <!-- ==================== 左侧导航栏 ==================== -->
        <Border Grid.Column="0" Background="#181825" CornerRadius="0" Margin="0,10,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Logo/系统名 -->
                    <RowDefinition Height="*"/>
                    <!-- 菜单项 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 底部用户信息 -->
                </Grid.RowDefinitions>

                <!-- 系统名称 -->
                <StackPanel Grid.Row="0" Margin="15,20,15,20">
                    <TextBlock Text="智慧农业系统" FontSize="18" FontWeight="Bold"
                               Foreground="#A6E3A1" HorizontalAlignment="Center"/>
                    <Border Background="#45475A" Height="1" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- 菜单导航 -->
                <StackPanel Grid.Row="1" Margin="10,0">
                    <!-- 数据监控 -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="0"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="15,10"
                            Cursor="Hand" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                               Foreground="#89B4FA" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="数据监控" FontSize="14" Foreground="#CDD6F4"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="0">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 蔬菜管理 -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="1"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="15,10"
                            Cursor="Hand" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                               Foreground="#A6E3A1" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="蔬菜管理" FontSize="14" Foreground="#CDD6F4"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="1">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 大棚管理 -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="2"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="15,10"
                            Cursor="Hand" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                               Foreground="#F9E2AF" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="大棚管理" FontSize="14" Foreground="#CDD6F4"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="2">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 设备管理 -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="3"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="15,10"
                            Cursor="Hand" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                               Foreground="#FAB387" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="设备管理" FontSize="14" Foreground="#CDD6F4"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="3">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 人员管理（仅管理员可见） -->
                    <Button Command="{Binding NavigateCommand}" CommandParameter="4"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="15,10"
                            Cursor="Hand" Margin="0,2"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                               Foreground="#F38BA8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="人员管理" FontSize="14" Foreground="#CDD6F4"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNavIndex}" Value="4">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- 底部用户信息和操作 -->
                <StackPanel Grid.Row="2" Margin="10,10,10,15">
                    <Border Background="#45475A" Height="1" Margin="5,0,5,10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                        <TextBlock Foreground="#CDD6F4" FontSize="13" VerticalAlignment="Center">
                            <Run Text="用户: "/>
                            <Run Text="{Binding CurrentUsername, Mode=OneWay}" FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="个人中心" Command="{Binding OpenProfileCommand}"
                                Background="#89B4FA" Foreground="#1E1E2E"
                                FontWeight="Bold" FontSize="11"
                                Padding="8,3" Margin="3,0"
                                Cursor="Hand"/>
                        <Button Content="退出登录" Command="{Binding LogoutCommand}"
                                Background="#F38BA8" Foreground="#1E1E2E"
                                FontWeight="Bold" FontSize="11"
                                Padding="8,3" Margin="3,0"
                                Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== 右侧内容区 ==================== -->
        <Grid Grid.Column="1" Margin="0,10,10,10">
            <!-- 页面0: 数据监控（默认） -->
            <Grid Margin="10" Visibility="{Binding SelectedNavIndex, Converter={StaticResource NavIndexToVisibilityConverter}, ConverterParameter=0}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <TextBlock Grid.Row="0" Text="数据监控" FontSize="20" FontWeight="Bold"
                           Foreground="#A6E3A1" VerticalAlignment="Center" Margin="10,0"/>

                <!-- 连接/断开按钮 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="连接" Command="{Binding ConnectCommand}"
                            Width="80" Margin="5" FontWeight="Bold" FontSize="14" Cursor="Hand" Foreground="#1E1E2E">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#89B4FA"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Background" Value="#45475A"/>
                                        <Setter Property="Foreground" Value="#6C7086"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="断开" Command="{Binding DisconnectCommand}"
                            Width="80" Margin="5" FontWeight="Bold" FontSize="14" Cursor="Hand" Foreground="#1E1E2E">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#6C7086"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Background" Value="#F38BA8"/>
                                        <Setter Property="Foreground" Value="#1E1E2E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="#CDD6F4" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <!-- 大棚监控卡片区域 -->
                <ItemsControl Grid.Row="2" ItemsSource="{Binding GreenhouseMonitorList}" Margin="5">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" Rows="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="8" CornerRadius="12" Padding="15,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#313244"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TempStatus}" Value="2">
                                                <Setter Property="BorderBrush" Value="#F38BA8"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HumidityStatus}" Value="2">
                                                <Setter Property="BorderBrush" Value="#F38BA8"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding TempStatus}" Value="1"/>
                                                    <Condition Binding="{Binding HumidityStatus}" Value="1"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="BorderBrush" Value="#F9E2AF"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <!-- 大棚名称 -->
                                    <TextBlock Text="{Binding greenhouseName}" FontSize="16" FontWeight="Bold"
                                               Foreground="#CDD6F4" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <!-- 作物名称 -->
                                    <TextBlock FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <Run Text="作物: " Foreground="#6C7086"/>
                                        <Run Text="{Binding cropName, Mode=OneWay}" Foreground="#A6E3A1" FontWeight="Bold"/>
                                    </TextBlock>

                                    <!-- 温度显示 -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                                        <TextBlock Text="温度" FontSize="12" Foreground="#6C7086"
                                                   VerticalAlignment="Center" Width="36"/>
                                        <TextBlock FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Width="80" TextAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#A6E3A1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TempStatus}" Value="1">
                                                            <Setter Property="Foreground" Value="#F9E2AF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TempStatus}" Value="2">
                                                            <Setter Property="Foreground" Value="#F38BA8"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="{Binding CurrentTemperature, StringFormat={}{0:F1}, Mode=OneWay}"/>
                                            <Run Text="℃"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="#6C7086" VerticalAlignment="Center" Margin="4,0,0,0">
                                            <Run Text="["/><Run Text="{Binding tempMin, Mode=OneWay}"/><Run Text="~"/><Run Text="{Binding tempMax, Mode=OneWay}"/><Run Text="]"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- 湿度显示 -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                                        <TextBlock Text="湿度" FontSize="12" Foreground="#6C7086"
                                                   VerticalAlignment="Center" Width="36"/>
                                        <TextBlock FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Width="80" TextAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#89B4FA"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HumidityStatus}" Value="1">
                                                            <Setter Property="Foreground" Value="#F9E2AF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HumidityStatus}" Value="2">
                                                            <Setter Property="Foreground" Value="#F38BA8"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="{Binding CurrentHumidity, StringFormat={}{0:F1}, Mode=OneWay}"/>
                                            <Run Text="%"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="#6C7086" VerticalAlignment="Center" Margin="4,0,0,0">
                                            <Run Text="["/><Run Text="{Binding humidityMin, Mode=OneWay}"/><Run Text="~"/><Run Text="{Binding humidityMax, Mode=OneWay}"/><Run Text="]"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- 分隔线 -->
                                    <Border Background="#45475A" Height="1" Margin="5,6,5,4"/>

                                    <!-- 温度调节器 -->
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="45"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="调温" FontSize="10" Foreground="#6C7086" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="50" IsSnapToTickEnabled="True" TickFrequency="0.5"
                                                Value="{Binding TargetTemperature, Mode=TwoWay}"
                                                VerticalAlignment="Center" Margin="2,0"
                                                Style="{DynamicResource CatppuccinSliderStyle}"/>
                                        <TextBlock Grid.Column="2" FontSize="10" Foreground="#A6E3A1" VerticalAlignment="Center" TextAlignment="Right">
                                            <Run Text="{Binding TargetTemperature, Mode=OneWay, StringFormat={}{0:F1}}"/><Run Text="℃"/>
                                        </TextBlock>
                                    </Grid>

                                    <!-- 湿度调节器 -->
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="45"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="调湿" FontSize="10" Foreground="#6C7086" VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" IsSnapToTickEnabled="True" TickFrequency="1"
                                                Value="{Binding TargetHumidity, Mode=TwoWay}"
                                                VerticalAlignment="Center" Margin="2,0"
                                                Style="{DynamicResource CatppuccinSliderStyle}"/>
                                        <TextBlock Grid.Column="2" FontSize="10" Foreground="#89B4FA" VerticalAlignment="Center" TextAlignment="Right">
                                            <Run Text="{Binding TargetHumidity, Mode=OneWay, StringFormat={}{0:F0}}"/><Run Text="%"/>
                                        </TextBlock>
                                    </Grid>

                                    <!-- 更新时间 -->
                                    <TextBlock FontSize="10" Foreground="#585B70" HorizontalAlignment="Center" Margin="0,4,0,0">
                                        <Run Text="更新: "/><Run Text="{Binding LastUpdateTime, StringFormat={}{0:HH:mm:ss}, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 预警信息栏 -->
                <Border Grid.Row="3" Background="#45475A" CornerRadius="5" Margin="10,5">
                    <TextBlock Text="{Binding LatestAlert}"
                               Foreground="#F38BA8" FontSize="13"
                               VerticalAlignment="Center" Margin="10,0"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>

            <!-- 页面1: 蔬菜管理 -->
            <local:CropManagementView Margin="10"
                                      DataContext="{Binding CropManagementVM}"
                                      Visibility="{Binding DataContext.SelectedNavIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NavIndexToVisibilityConverter}, ConverterParameter=1}"/>

            <!-- 页面2: 大棚管理 -->
            <local:GreenhouseManagementView Margin="10"
                                            DataContext="{Binding GreenhouseManagementVM}"
                                            Visibility="{Binding DataContext.SelectedNavIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NavIndexToVisibilityConverter}, ConverterParameter=2}"/>

            <!-- 页面3: 设备管理 -->
            <local:DeviceManagementView Margin="10"
                                        DataContext="{Binding DeviceManagementVM}"
                                        Visibility="{Binding DataContext.SelectedNavIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NavIndexToVisibilityConverter}, ConverterParameter=3}"/>

            <!-- 页面4: 人员管理（仅管理员） -->
            <local:UserManagementView Margin="10"
                                      DataContext="{Binding UserManagementVM}"
                                      Visibility="{Binding DataContext.SelectedNavIndex, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NavIndexToVisibilityConverter}, ConverterParameter=4}"/>
        </Grid>
    </Grid>
</Window>
