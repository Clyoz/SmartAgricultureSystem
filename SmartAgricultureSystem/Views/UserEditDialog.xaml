<Window x:Class="SmartAgricultureSystem.Views.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑用户" Height="450" Width="400"
        Background="#1E1E2E" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 新增时显示用户名和密码 -->
        <StackPanel x:Name="PanelNewUser" Grid.Row="0" Margin="0,0,0,5">
            <TextBlock Text="用户名:" Foreground="#CDD6F4" Margin="0,5"/>
            <TextBox x:Name="TxtUsername" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>
            <TextBlock Text="密码:" Foreground="#CDD6F4" Margin="0,5"/>
            <PasswordBox x:Name="TxtPassword" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="昵称:" Foreground="#CDD6F4" Margin="0,5"/>
        <TextBox Grid.Row="2" x:Name="TxtNickname" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>

        <Grid Grid.Row="3" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="角色:" Foreground="#CDD6F4" Margin="0,5"/>
                <ComboBox x:Name="CmbRole" Background="#313244" Foreground="White" Padding="5" Margin="0,2" SelectedIndex="1">
                    <ComboBoxItem Content="管理员"/>
                    <ComboBoxItem Content="农户"/>
                    <ComboBoxItem Content="技术人员"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="锁定状态:" Foreground="#CDD6F4" Margin="0,5"/>
                <CheckBox x:Name="ChkLocked" Content="已锁定" Foreground="#F38BA8"
                          FontSize="13" VerticalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="4" Text="邮箱:" Foreground="#CDD6F4" Margin="0,8,0,5"/>
        <TextBox Grid.Row="5" x:Name="TxtEmail" Background="#313244" Foreground="White" Padding="5" Margin="0,2"/>

        <TextBlock Grid.Row="6" Text="备注:" Foreground="#CDD6F4" Margin="0,8,0,5"/>
        <TextBox Grid.Row="7" x:Name="TxtRemark" Background="#313244" Foreground="White" Padding="5" Margin="0,2"
                 TextWrapping="Wrap" AcceptsReturn="True" Height="50" VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="保存" Click="BtnSave_Click" Width="80" Margin="5,0"
                    Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="取消" Click="BtnCancel_Click" Width="80" Margin="5,0"
                    Background="#45475A" Foreground="#CDD6F4" FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
