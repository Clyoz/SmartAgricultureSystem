<UserControl x:Class="SmartAgricultureSystem.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,0">
            <TextBlock Text="人员管理" FontSize="20" FontWeight="Bold"
                       Foreground="#F38BA8" VerticalAlignment="Center"/>
            <TextBlock Text="管理登录账号、查看登录日志（仅管理员）" FontSize="13"
                       Foreground="#6C7086" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- 操作栏 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,5">
            <Button Content="添加用户" Command="{Binding AddUserCommand}"
                    Background="#A6E3A1" Foreground="#1E1E2E"
                    FontWeight="Bold" FontSize="12" Padding="12,5" Margin="0,0,10,0" Cursor="Hand"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="Bold" FontSize="12" Padding="12,5" Margin="0,0,10,0" Cursor="Hand"/>
            <TextBlock Text="登录日志" FontSize="14" FontWeight="Bold"
                       Foreground="#F9E2AF" VerticalAlignment="Center" Margin="20,0,10,0"/>
            <Button Content="查看日志" Command="{Binding ShowLoginLogsCommand}"
                    Background="#F9E2AF" Foreground="#1E1E2E"
                    FontWeight="Bold" FontSize="12" Padding="12,5" Cursor="Hand"/>
        </StackPanel>

        <!-- 用户列表 -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding UserList}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#313244" Foreground="White"
                  RowBackground="#45475A" AlternatingRowBackground="#313244"
                  Margin="10,5" SelectedItem="{Binding SelectedUser}"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                <DataGridTextColumn Header="用户名" Binding="{Binding username}" Width="100"/>
                <DataGridTextColumn Header="昵称" Binding="{Binding nickname}" Width="100"/>
                <DataGridTextColumn Header="角色" Width="80">
                    <DataGridTextColumn.Binding>
                        <Binding Path="role"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="手机号" Binding="{Binding phoneNumber}" Width="120"/>
                <DataGridTextColumn Header="邮箱" Binding="{Binding email}" Width="150"/>
                <DataGridTextColumn Header="锁定" Binding="{Binding isLocked}" Width="50"/>
                <DataGridTextColumn Header="注册时间" Binding="{Binding createdAt, StringFormat={}{0:yyyy-MM-dd}}" Width="100"/>
                <DataGridTextColumn Header="最后登录" Binding="{Binding lastLoginAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130"/>
                <DataGridTextColumn Header="备注" Binding="{Binding remark}" Width="*"/>
                <DataGridTemplateColumn Header="操作" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="编辑" Click="BtnEditUser_Click"
                                        Background="#F9E2AF" Foreground="#1E1E2E"
                                        FontWeight="Bold" FontSize="11" Padding="6,2" Margin="1,0" Cursor="Hand"/>
                                <Button Content="删除" Click="BtnDeleteUser_Click"
                                        Background="#F38BA8" Foreground="#1E1E2E"
                                        FontWeight="Bold" FontSize="11" Padding="6,2" Margin="1,0" Cursor="Hand"/>
                                <Button Content="重置密码" Click="BtnResetPassword_Click"
                                        Background="#89B4FA" Foreground="#1E1E2E"
                                        FontWeight="Bold" FontSize="11" Padding="6,2" Margin="1,0" Cursor="Hand"/>
                                <Button Content="解锁" Click="BtnUnlockUser_Click"
                                        Background="#A6E3A1" Foreground="#1E1E2E"
                                        FontWeight="Bold" FontSize="11" Padding="6,2" Margin="1,0" Cursor="Hand"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="3" Background="#313244" CornerRadius="5" Margin="10,2">
            <TextBlock Foreground="#6C7086" FontSize="12" VerticalAlignment="Center" Margin="10,0">
                <Run Text="共 "/><Run Text="{Binding UserList.Count, Mode=OneWay}"/><Run Text=" 个用户"/>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
