<UserControl x:Class="SmartAgricultureSystem.Views.CropManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,0">
            <TextBlock Text="蔬菜管理" FontSize="20" FontWeight="Bold"
                       Foreground="#A6E3A1" VerticalAlignment="Center"/>
            <TextBlock Text="管理作物品种、适宜环境参数" FontSize="13"
                       Foreground="#6C7086" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- 操作栏 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,5">
            <Button Content="添加作物" Command="{Binding AddCropCommand}"
                    Background="#A6E3A1" Foreground="#1E1E2E"
                    FontWeight="Bold" FontSize="12" Padding="12,5" Margin="0,0,10,0" Cursor="Hand"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="Bold" FontSize="12" Padding="12,5" Cursor="Hand"/>
            <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                     Width="200" Margin="20,0,0,0" Background="#313244" Foreground="White"
                     Padding="5" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding CropList}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#313244" Foreground="White"
                  RowBackground="#45475A" AlternatingRowBackground="#313244"
                  Margin="10,5" SelectedItem="{Binding SelectedCrop}"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="50"/>
                <DataGridTextColumn Header="作物名称" Binding="{Binding cropName}" Width="100"/>
                <DataGridTextColumn Header="品种" Binding="{Binding variety}" Width="100"/>
                <DataGridTextColumn Header="温度范围(℃)" Width="120">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0:F0}~{1:F0}">
                            <Binding Path="tempMin"/>
                            <Binding Path="tempMax"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="湿度范围(%)" Width="120">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0:F0}~{1:F0}">
                            <Binding Path="humidityMin"/>
                            <Binding Path="humidityMax"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="生长周期(天)" Binding="{Binding growthCycleDays}" Width="100"/>
                <DataGridTextColumn Header="说明" Binding="{Binding description}" Width="*"/>
                <DataGridTemplateColumn Header="操作" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="编辑" Click="BtnEditCrop_Click"
                                        Background="#F9E2AF" Foreground="#1E1E2E"
                                        FontWeight="Bold" FontSize="11" Padding="8,2" Margin="2,0" Cursor="Hand"/>
                                <Button Content="删除" Click="BtnDeleteCrop_Click"
                                        Background="#F38BA8" Foreground="#1E1E2E"
                                        FontWeight="Bold" FontSize="11" Padding="8,2" Margin="2,0" Cursor="Hand"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
